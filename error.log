@@ -0,0 +1,114 @@
+"""Index project string constants for repeated literal hinting."""
+
+from __future__ import annotations
+
+import ast
+import re
+from collections import defaultdict
+from functools import lru_cache
+from pathlib import Path
+from typing import Final
+
+_CONSTANT_FILE_NAMES: Final[tuple[str, ...]] = (
+    "constants.py",
+    "config.py",
+    "settings.py",
+    "defaults.py",
+)
+
+_DEFAULT_CONST_NAME_PATTERN: Final[str] = r"^[A-Z][A-Z0-9_]*$"
+
+
+def normalize_string_literal(value: str) -> str:
+    """Normalize a literal value before lookup in the constant index."""
+    return value.strip()
+
+
+def _is_constant_name(name: str, pattern: re.Pattern[str]) -> bool:
+    return bool(pattern.match(name))
+
+
+def _candidate_paths(project_root: Path) -> list[Path]:
+    candidates: list[Path] = []
+    seen: set[Path] = set()
+    for base in (project_root, project_root / "src", project_root / "app", project_root / "config"):
+        if not base.exists() or not base.is_dir():
+            continue
+        for file_name in _CONSTANT_FILE_NAMES:
+            for candidate in base.rglob(file_name):
+                resolved = candidate.resolve()
+                if not candidate.is_file() or resolved in seen:
+                    continue
+                seen.add(resolved)
+                candidates.append(candidate)
+    return candidates
+
+
+def _string_constant_refs(
+    file_path: Path,
+    *,
+    const_name_pattern: re.Pattern[str],
+) -> list[tuple[str, int, str]]:
+    source = file_path.read_text(encoding="utf-8")
+    tree = ast.parse(source)
+    refs: list[tuple[str, int, str]] = []
+
+    for node in ast.walk(tree):
+        if isinstance(node, ast.Assign):
+            if not isinstance(node.value, ast.Constant) or not isinstance(node.value.value, str):
+                continue
+            for target in node.targets:
+                if not isinstance(target, ast.Name):
+                    continue
+                if not _is_constant_name(target.id, const_name_pattern):
+                    continue
+                refs.append((target.id, node.lineno, node.value.value))
+        elif isinstance(node, ast.AnnAssign):
+            if not isinstance(node.target, ast.Name):
+                continue
+            if not isinstance(node.value, ast.Constant) or not isinstance(node.value.value, str):
+                continue
+            if not _is_constant_name(node.target.id, const_name_pattern):
+                continue
+            refs.append((node.target.id, node.lineno, node.value.value))
+
+    return refs
+
+
+@lru_cache(maxsize=32)
+def _cached_constant_string_index(
+    project_root: str,
+    const_name_pattern: str = _DEFAULT_CONST_NAME_PATTERN,
+) -> dict[str, tuple[tuple[str, str, int], ...]]:
+    root_path = Path(project_root)
+    pattern = re.compile(const_name_pattern)
+    index: dict[str, list[tuple[str, str, int]]] = defaultdict(list)
+
+    for path in _candidate_paths(root_path):
+        relative = path.relative_to(root_path).as_posix()
+        try:
+            for const_name, line_no, literal in _string_constant_refs(
+                path,
+                const_name_pattern=pattern,
+            ):
+                normalized = normalize_string_literal(literal)
+                index[normalized].append((const_name, relative, line_no))
+        except (OSError, SyntaxError, UnicodeDecodeError):
+            continue
+
+    return {key: tuple(value) for key, value in index.items()}
+
+
+def build_constant_string_index(
+    project_root: Path,
+    *,
+    const_name_pattern: str = _DEFAULT_CONST_NAME_PATTERN,
+) -> dict[str, tuple[tuple[str, str, int], ...]]:
+    """Build (or fetch) constant lookup map for this project root."""
+    root = str(project_root.resolve())
+    return _cached_constant_string_index(root, const_name_pattern)
+
+
+def clear_constant_string_index_cache() -> None:
+    """Clear process-local constant index cache (test helper)."""
+    _cached_constant_string_index.cache_clear()
