+    func = node.func
+    if isinstance(func, ast.Attribute):
+        if isinstance(func.value, ast.Name):
+            return func.value.id in {"logger", "logging"}
+        return func.attr in {"error", "warning", "warn", "exception", "info"}
+    return False
