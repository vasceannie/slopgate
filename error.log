+# ===========================================================================
+# Unit tests: repeated-string-literal constant hints
+# ===========================================================================
+
+
+class TestRepeatedStringLiteralConstantHints:
+    def setup_method(self) -> None:
+        clear_constant_string_index_cache()
+
+    def _configure_lint_for(self, root: Path, *, max_repeats: int = 1) -> None:
+        cfg = load_config(root)
+        set_config(replace(cfg, max_repeated_string_literals=max_repeats))
+
+    def test_exact_match_found(self, tmp_path: Path) -> None:
+        src_dir = tmp_path / "src"
+        _mkdir(src_dir, exist_ok=True)
+        _write_text(src_dir / "constants.py", "ERROR_TIMEOUT_MSG = 'Timeout occurred'\n")
+        _write_text(src_dir / "a.py", "MSG = 'Timeout occurred'\n")
+        _write_text(src_dir / "b.py", "MSG = 'Timeout occurred'\n")
+        self._configure_lint_for(tmp_path)
+
+        violations = detect_repeated_literals([src_dir / "a.py", src_dir / "b.py"])
+
+        repeated = [v for v in violations if v.rule == "repeated-string-literal"]
+        assert repeated, "Expected repeated-string-literal violation"
+        detail = repeated[0].detail
+        assert "Existing constant(s): `src/constants.py:ERROR_TIMEOUT_MSG`" in detail
+        assert detail.count("`src/constants.py:ERROR_TIMEOUT_MSG`") == 1
+
+    def test_no_match_keeps_extraction_guidance(self, tmp_path: Path) -> None:
+        src_dir = tmp_path / "src"
+        _mkdir(src_dir, exist_ok=True)
+        _write_text(src_dir / "a.py", "MSG = 'No constant for me'\n")
+        _write_text(src_dir / "b.py", "MSG = 'No constant for me'\n")
+        self._configure_lint_for(tmp_path)
+
+        violations = detect_repeated_literals([src_dir / "a.py", src_dir / "b.py"])
+
+        repeated = [v for v in violations if v.rule == "repeated-string-literal"]
+        assert repeated, "Expected repeated-string-literal violation"
+        assert "extract to a shared constant" in repeated[0].detail
+        assert "Existing constant(s):" not in repeated[0].detail
+
+    def test_multiple_matches(self, tmp_path: Path) -> None:
+        src_dir = tmp_path / "src"
+        app_dir = tmp_path / "app"
+        _mkdir(src_dir, exist_ok=True)
+        _mkdir(app_dir, exist_ok=True)
+        _write_text(src_dir / "constants.py", "ERROR_MSG = 'Boom'\n")
+        _write_text(app_dir / "settings.py", "FALLBACK_ERROR_MSG = 'Boom'\n")
+        _write_text(src_dir / "a.py", "X = 'Boom'\n")
+        _write_text(src_dir / "b.py", "Y = 'Boom'\n")
+        self._configure_lint_for(tmp_path)
+
+        violations = detect_repeated_literals([src_dir / "a.py", src_dir / "b.py"])
+
+        repeated = [v for v in violations if v.rule == "repeated-string-literal"]
+        assert repeated, "Expected repeated-string-literal violation"
+        detail = repeated[0].detail
+        assert "`src/constants.py:ERROR_MSG`" in detail
+        assert "`app/settings.py:FALLBACK_ERROR_MSG`" in detail
+        assert detail.count("`src/constants.py:ERROR_MSG`") == 1
+        assert detail.count("`app/settings.py:FALLBACK_ERROR_MSG`") == 1
+
+    def test_non_string_constants_ignored(self, tmp_path: Path) -> None:
+        src_dir = tmp_path / "src"
+        _mkdir(src_dir, exist_ok=True)
+        _write_text(src_dir / "constants.py", "TIMEOUT_SECONDS = 30\n")
+        _write_text(src_dir / "a.py", "MSG = 'Same text'\n")
+        _write_text(src_dir / "b.py", "MSG = 'Same text'\n")
+        self._configure_lint_for(tmp_path)
+
+        violations = detect_repeated_literals([src_dir / "a.py", src_dir / "b.py"])
+
+        repeated = [v for v in violations if v.rule == "repeated-string-literal"]
+        assert repeated, "Expected repeated-string-literal violation"
+        assert "Existing constant(s):" not in repeated[0].detail

