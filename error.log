 def _command_has_word(command: str, word: str) -> bool:
     """Check if *word* appears as a standalone token in *command*."""
     escaped = re.escape(word)
     pattern = rf"(^|\s){escaped}(\s|$)"
     return bool(re.search(pattern, command, re.IGNORECASE))
 
 
